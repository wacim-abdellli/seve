## The Fix — 3 Changes

### Change 1: Make `getPageBreakSections()` actually split content

**FILE**: [layoutHelper.ts](file:///c:/Users/pc/Desktop/seve/src/utils/layoutHelper.ts)

**REPLACE the entire `getPageBreakSections` function** (lines 45-64) with:

```typescript
export function getPageBreakSections(
  resumeData: ResumeData,
  sectionOrder: string[],
  fontSize: number = 10
): {
  page1Sections: string[];
  page2Sections: string[];
} {
  const hasContent = (key: string): boolean => {
    if (key === 'summary') return !!(resumeData.summary && resumeData.summary.trim() !== '')
    if (key === 'skills') return !!(resumeData.skills && resumeData.skills.length > 0)
    const val = (resumeData as unknown as Record<string, unknown>)[key]
    return Array.isArray(val) && val.length > 0
  }

  const activeSections = sectionOrder.filter(hasContent)
  const heights = getSectionHeights(resumeData, fontSize)

  // A4 usable height in px (1123px total - ~96px padding top/bottom)
  const PAGE_1_BUDGET = USABLE_PER_PAGE
  const page1Sections: string[] = []
  const page2Sections: string[] = []
  let usedHeight = 0

  // Contact header always takes ~80px, accounted for in budget
  const contactHeight = heights.contact || 80
  usedHeight += contactHeight

  for (const sec of activeSections) {
    const sectionHeight = heights[sec] || 60

    if (usedHeight + sectionHeight <= PAGE_1_BUDGET) {
      // Fits on page 1
      page1Sections.push(sec)
      usedHeight += sectionHeight
    } else {
      // Doesn't fit — push to page 2
      page2Sections.push(sec)
    }
  }

  // OPTIMIZATION: If page 2 has very little content (< 20% of a page),
  // try to pull the last section from page 1 to page 2 to balance better
  // (prevents a mostly-empty page 2)
  // Actually: if page2 total is tiny, keep everything on page1 and let CSS handle it.
  const page2TotalHeight = page2Sections.reduce((sum, sec) => sum + (heights[sec] || 60), 0)
  if (page2Sections.length > 0 && page2TotalHeight < USABLE_PER_PAGE * 0.15) {
    // Page 2 would be < 15% full — just put everything on page 1
    // Let the browser's natural overflow handle the tiny spillover
    return { page1Sections: [...page1Sections, ...page2Sections], page2Sections: [] }
  }

  return { page1Sections, page2Sections }
}
```

Also update the function signature for `getPageBreakSections` usage in [useTemplateData.ts:73](file:///c:/Users/pc/Desktop/seve/src/components/templates/useTemplateData.ts#L73):
```typescript
// OLD:
const { page1Sections, page2Sections } = getPageBreakSections(data, sectionOrder)
// NEW:
const { page1Sections, page2Sections } = getPageBreakSections(data, sectionOrder, 10)
```

